# Copy to .env for local dev, OR set as Environment Variables in CylonCloud deploy panel
# VITE_API_URL must be set to your deployed Java backend URL before building

# Local dev
VITE_API_URL=http://localhost:8080
VITE_APP_NAME=ReactStoreApp

# CylonCloud deploy example
# VITE_API_URL=https://your-java-backend.cyloncloud.com
